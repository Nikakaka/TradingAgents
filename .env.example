# ============================================================
# TradingAgents 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入您的密钥
# 至少需要一个 LLM 提供商的 API 密钥

# ------------------------------------------------------------
# LLM 提供商（至少设置一个）
# ------------------------------------------------------------
OPENAI_API_KEY=              # OpenAI GPT 模型
GOOGLE_API_KEY=              # Google Gemini 模型
ANTHROPIC_API_KEY=           # Anthropic Claude 模型
XAI_API_KEY=                 # xAI Grok 模型
ZHIPUAI_API_KEY=             # 智谱AI (GLM) 模型
OPENROUTER_API_KEY=          # OpenRouter API 网关

# ------------------------------------------------------------
# 数据源（可选）
# ------------------------------------------------------------
ALPHA_VANTAGE_API_KEY=       # Alpha Vantage 全球股票数据
IFIND_REFRESH_TOKEN=         # 同花顺 iFinD 刷新令牌（付费，数据最全面）

# ------------------------------------------------------------
# 通知与账户（可选）
# ------------------------------------------------------------
TRADING_ACCOUNT_ID=          # 交易账户标识符
FEISHU_WEBHOOK_URL=          # 飞书通知 Webhook URL

# ------------------------------------------------------------
# 高级配置（可选）
# ------------------------------------------------------------
TRADINGAGENTS_RESULTS_DIR=   # 结果输出目录（默认 ./results）
